{
  "siteMetadata": {
    "language": "en",
    "siteUrl": "https://gatsby-starter-portfolio-minimal-theme.netlify.app/",
    "title": "Marina Russ | Portfolio",
    "titleTemplate": "%s · Portfolio Minimal",
    "description": "Front end developer portfolio",
    "author": "Marina Russ",
    "avatar": "../content/images/gatsby.png",
    "bio": "This biography will be used in the footer area of an article and can contain some more details about the author.",
    "social": {
      "behance": "https://behance.com",
      "github": "https://github.com/marina-russ",
      "medium": "https://medium.com",
      "linkedin": "https://www.linkedin.com/in/marinaruss/",
      "mail": "mailto:mrusscode@gmail.com"
    }
  },
  "siteConfiguration": {
    "logo": { "text": "Marina Russ" },
    "navigation": {
      "header": [
        { "label": "About", "url": "/#about" },
        { "label": "Skills", "url": "/#skills" },
        { "label": "Projects", "url": "/#projects" },
        { "label": "Contact", "url": "/#contact" }
      ],
      "ctaButton": {
        "openNewTab": true,
        "label": "Resume",
        "url": "/marina-russ-resume.pdf"
      },
      "footer": [
      ]
    },
    "featureToggles": {
      "useDarkModeAsDefault": true,
      "useDarkModeBasedOnUsersPreference": true,
      "useCookieBar": false
    }
